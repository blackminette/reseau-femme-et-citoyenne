generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Utilisateur {
  id              String              @id @default(cuid())
  email           String              @unique
  nom             String
  prenom          String
  telephone       String?
  role            String              @default("MEMBRE")
  createdAt       DateTime            @default(now())
  tuteurId        String?
  username        String              @unique
  isActive        Boolean             @default(true)
  avatar          String?             @default("🦊 bg-[#b6e3f4]")
  ateliersPrives  Atelier[]           @relation("PartenaireAtelier")
  suggestions     BoiteAIdees[]
  coursAnimes     Cours[]             @relation("IntervenanteCours")
  dons            Don[]
  messagesEnvoyes MessageContact[]
  reservations    Reservation[]
  ScoreQuiz       ScoreQuiz[]
  temoignages     Temoignage[]
  tentatives      TentativeExercice[]
  completionsCours CompletionCours[]
  progressionsFormation ProgressionFormation[]
  tuteur          Utilisateur?        @relation("ParentEnfant", fields: [tuteurId], references: [id], onDelete: Cascade)
  enfants         Utilisateur[]       @relation("ParentEnfant")
  badges          Badge[]
}

model Badge {
  id          Int         @id @default(autoincrement())
  label       String
  iconName    String
  desc        String
  createdAt   DateTime    @default(now())
  etudiantId  String
  Utilisateur Utilisateur @relation(fields: [etudiantId], references: [id], onDelete: Cascade)
}

model Atelier {
  id                Int           @id @default(autoincrement())
  titre             String
  description       String?
  placesMax         Int           @default(15)
  trancheAge        String?
  public           PublicCible   @default(ENFANT)
  estPrive          Boolean       @default(false)
  typePaiement      String?
  creneauVerrouille Boolean       @default(false)
  effectifPrevu     Int?
  partenaireId      String?
  dateDebut         DateTime
  dateFin           DateTime
  lieuId            String
  lieu              Lieu          @relation(fields: [lieuId], references: [id])
  partenaire        Utilisateur?  @relation("PartenaireAtelier", fields: [partenaireId], references: [id], onDelete: Cascade)
  reservations      Reservation[]
}

model Lieu {
  id           String    @id @default(cuid())
  nom          String
  adresseTexte String
  adresseIdBan String    @unique @default("")
  estExterieur Boolean   @default(false)
  ateliers     Atelier[]
}

model Reservation {
  id              Int         @id @default(autoincrement())
  dateReservation DateTime    @default(now())
  statut          String      @default("PENDING")

  nom             String?     
  email           String?     
  telephone       String?     

  modePaiement    String?   
  statutPaiement  String      @default("EN_ATTENTE") 

  utilisateurId   String?     
  utilisateur     Utilisateur? @relation(fields: [utilisateurId], references: [id], onDelete: Cascade)

  atelierId       Int
  atelier         Atelier     @relation(fields: [atelierId], references: [id], onDelete: Cascade)

  @@unique([utilisateurId, atelierId])
}

model Module {
  id          Int         @id @default(autoincrement())
  titre       String
  description String?
  createdAt   DateTime    @default(now())
  public      PublicCible @default(ADULTE)
  isPublished Boolean     @default(false)
  parcours    Parcours[]
  difficulte  Difficulte  @default(FACILE)
  cours       Cours[]
}

model Cours {
  id              Int               @id @default(autoincrement())
  titre           String
  estPublic       Boolean           @default(true)
  createdAt       DateTime          @default(now())
  intervenanteId  String
  contenu         Json              @default("[]")
  moduleId        Int
  ordreDansModule Int               @default(1)
  difficulte      Difficulte        @default(FACILE)
  completions     CompletionCours[]
  intervenante    Utilisateur       @relation("IntervenanteCours", fields: [intervenanteId], references: [id], onDelete: Cascade)
  module          Module            @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  exercices       Exercice[]
  programmes      Programme[]
}

model Exercice {
  id           Int                 @id @default(autoincrement())
  titre        String
  instructions String
  type         String
  contenu      Json                @default("[]")
  coursId      Int
  ordre        Int                 @default(1)
  competence   String?
  difficulte   Difficulte          @default(FACILE)
  cours        Cours               @relation(fields: [coursId], references: [id], onDelete: Cascade)
  scores       ScoreQuiz[]
  tentatives   TentativeExercice[]
}

model ScoreQuiz {
  id          Int         @id @default(autoincrement())
  score       Int
  createdAt   DateTime    @default(now())
  etudiantId  String
  exerciceId  Int
  Utilisateur Utilisateur @relation(fields: [etudiantId], references: [id], onDelete: Cascade)
  exercice    Exercice    @relation(fields: [exerciceId], references: [id])
}

model TentativeExercice {
  id                Int         @id @default(autoincrement())
  createdAt         DateTime    @default(now())
  score             Int
  totalQuestions    Int
  bonnesReponses    Int
  mauvaisesReponses Int
  dureeSecondes     Int?
  assistee          Boolean     @default(false)
  etudiantId        String
  exerciceId        Int
  Utilisateur       Utilisateur @relation(fields: [etudiantId], references: [id], onDelete: Cascade)
  exercice          Exercice    @relation(fields: [exerciceId], references: [id], onDelete: Cascade)
}

model Programme {
  id                Int      @id @default(autoincrement())
  datePlanification DateTime
  coursId           Int
  cours             Cours    @relation(fields: [coursId], references: [id])
}

model CompletionCours {
  id          Int         @id @default(autoincrement())
  createdAt   DateTime    @default(now())
  etudiantId  String
  coursId     Int
  Utilisateur Utilisateur @relation(fields: [etudiantId], references: [id], onDelete: Cascade)
  cours       Cours       @relation(fields: [coursId], references: [id], onDelete: Cascade)

  @@unique([etudiantId, coursId])
}

model BoiteAIdees {
  id         Int         @id @default(autoincrement())
  sujet      String
  suggestion String
  createdAt  DateTime    @default(now())
  membreId   String
  membre     Utilisateur @relation(fields: [membreId], references: [id], onDelete: Cascade)
}

model Don {
  id            Int         @id @default(autoincrement())
  montant       Float
  dateDon       DateTime    @default(now())
  statut        String      @default("COMPLETED")
  utilisateurId String
  utilisateur   Utilisateur @relation(fields: [utilisateurId], references: [id], onDelete: Cascade)
}

model Temoignage {
  id            Int         @id @default(autoincrement())
  contenu       String
  estValide     Boolean     @default(false)
  createdAt     DateTime    @default(now())
  utilisateurId String
  utilisateur   Utilisateur @relation(fields: [utilisateurId], references: [id], onDelete: Cascade)
}

model Actualite {
  id              Int      @id @default(autoincrement())
  titre           String
  tag             String
  datePublication DateTime
  extrait         String
  ctaLabel        String   @default("Lire la suite")
  ctaHref         String   @default("/ateliers")
  ordre           Int      @default(1)
  estPublic       Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model MessageContact {
  id            Int          @id @default(autoincrement())
  nom           String
  email         String
  sujet         String
  message       String
  envoyeLe      DateTime     @default(now())
  utilisateurId String?
  utilisateur   Utilisateur? @relation(fields: [utilisateurId], references: [id], onDelete: Cascade)
}

enum PublicCible {
  ENFANT
  ADULTE
}

enum Parcours {
  COMPREHENSION_LECTURE
  ECO_CITOYENNETE
  EDUCATION_CIVIQUE
  NUMERIQUE
  ANGLAIS
  ROBOTIQUE
  NUMERIQUE_ADULTE
  ORAL
  BUREAUTIQUE
}

enum Difficulte {
  FACILE
  MOYEN
  DIFFICILE
}

model ProgressionFormation {
  id            Int         @id @default(autoincrement())
  utilisateurId String
  utilisateur   Utilisateur @relation(fields: [utilisateurId], references: [id], onDelete: Cascade)
  moduleCle     String      // identifiant du module côté front (ex: "fichiers-windows")
  etapeActuelle Int         @default(0) // dernière étape atteinte (0 = pas commencé)
  totalEtapes   Int         @default(1) // nombre total d'étapes du module
  scoreQuiz     Int?        // nombre de bonnes réponses au quiz (null = quiz pas encore passé)
  totalQuiz     Int?        // nombre total de questions du quiz
  terminee      Boolean     @default(false)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@unique([utilisateurId, moduleCle])
}
